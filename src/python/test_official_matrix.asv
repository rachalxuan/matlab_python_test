clc;
clear;

snrList = 0:2:20;

ber = zeros(size(snrList));
evm = zeros(size(snrList));
mer = zeros(size(snrList));
lock = zeros(size(snrList));

for k = 1:length(snrList)

    snrNow = snrList(k);
    fprintf('\n==============================\n');
    fprintf('running snr = %.1f dB \n',snrNow);
    fprintf('\n==============================\n');

    p = struct( ...
        'modType','8PSK', ...
        'symbolRate',1e6, ...
        'sps',8, ...
        'snr',snrNow, ...
        'cfo',3000, ...
        'phaseOffset',30, ...
        'delay',0.35, ...
        'channelCoding','convolutional', ...
        'ConvolutionalCodeRate','2/3', ...
        'RolloffFactor',0.35, ...
        'hasASM',true, ...
        'showFigures',false);

    out = run_ccsds_tm_evaluation(p);

    r = jsonencode(out);

    ber(k) = r.BER;
    evm(k) = r.EVM_post_pct;
    mer(k) = r.MER_dB;
    lock(k) = r.LockRate;


end
figure;

semilogx(snrList,ber);
grid on;
xlabel('SNR(dB)');
ylabel('ber');
title('8PSK BER vs SNR');
ylim([1e-5 1]);



